# Agent Configuration

# WebSocket server URL
SERVER_URL=wss://your-server.com

# Agent display name
AGENT_NAME=MyPC

# Agent authentication secret (must match server's AGENT_SECRET)
AGENT_SECRET=your-agent-secret-here

# Default working directory for Claude
# Windows: WORK_DIR=C:\Projects
# Linux/macOS: WORK_DIR=/home/user/projects
WORK_DIR=
